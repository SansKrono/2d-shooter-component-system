[gd_resource type="Resource" script_class="Relic" format=3]

[ext_resource type="Script" path="res://resources/effects/zigzag_path_modifier.gd" id="1_zigzag_mod"]
[ext_resource type="Script" path="res://resources/effects/apply_bullet_path_effect.gd" id="2_apply_path_effect"]
[ext_resource type="Script" path="res://resources/relic.gd" id="3_relic"]

[sub_resource type="Resource" id="Resource_zigzag"]
script = ExtResource("1_zigzag_mod")
frequency = 15.0
amplitude = 20.0

[sub_resource type="Resource" id="Resource_apply_path"]
script = ExtResource("2_apply_path_effect")
path_modifier = SubResource("Resource_zigzag")

[resource]
script = ExtResource("3_relic")
name = "Wiggle Worm"
description = "Makes projectiles zig-zag left and right."
effects = Array[Resource]([SubResource("Resource_apply_path")])
